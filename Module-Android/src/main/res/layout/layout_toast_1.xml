<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:minHeight="64dp"
    android:background="@drawable/ic_shadow_bg"
    android:layout_height="wrap_content"
    android:layout_width="match_parent">

    <androidx.appcompat.widget.AppCompatImageView
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/icon"
        android:visibility="gone"
        tools:visibility="visible"
        android:layout_width="20dp"
        android:layout_height="20dp"
        tools:src="@drawable/ic_successful"/>

    <com.au.module_android.text.CustomTextView
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/icon"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginStart="12dp"
        android:id="@+id/text"
        style="@style/StyleNormalText"
        android:maxLines="3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:textSize="14sp"
        tools:text="The recipy dfjksdafhjkf jkfjk 18949i 489 22 cooool!!! djkfdasjkf zxcjvk 83204i jadskfja 18904 ajdkfa 182941j makxsf  81294 adjkf 189023 jdfka 12891 dskjf" />
</androidx.constraintlayout.widget.ConstraintLayout>