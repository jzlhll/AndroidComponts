<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="CustomModuleThemeDark" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/color_text_normal_dark</item>
        <item name="colorPrimaryDark">@color/color_text_dark_secondary</item>
        <item name="colorAccent">@color/color_primary_dark</item>
        <item name="android:colorControlNormal">#121212</item>
        <!-- 自定义菜单项文字颜色 -->
        <item name="android:actionMenuTextColor">@color/color_text_normal_dark</item>

        <item name="android:textColorPrimary">#121212</item>
        <item name="colorPrimaryVariant">#333333</item>
        <!-- 重要的4板斧 设置statusBar和navigationBar的颜色-->
        <item name="android:statusBarColor">@color/color_background_app_dark</item>
        <item name="android:navigationBarColor">@color/color_background_app_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:windowBackground">@color/color_background_app_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:navigationBarDividerColor" tools:targetApi="o_mr1">
            @android:color/transparent
        </item>
    </style>
</resources>