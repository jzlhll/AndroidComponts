<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:minHeight="224dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        app:backgroundNormal="@color/color_white"
        app:cornerSizeTopLeft="12dp"
        app:cornerSizeTopRight="12dp"
        app:cornerSizeBottomLeft="12dp"
        app:cornerSizeBottomRight="12dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_successful"
            android:layout_width="80dp"
            android:layout_height="80dp"/>

        <com.au.module_android.text.CustomFontText
            android:id="@+id/tvTitle"
            style="@style/TyiotFontBText"
            android:textColor="@color/color_text_normal"
            app:layout_constraintTop_toBottomOf="@id/icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:maxLines="3"
            android:textSize="@dimen/text_size_h3_20sp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            tools:text="fir" />

        <com.au.module_android.text.CustomFontText
            android:id="@+id/tvContent"
            style="@style/TyiotMinText"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            tools:text="Your customiz" />

        <com.au.module_android.text.CustomButton
            android:id="@+id/btnCancel"
            style="@style/IotButtonGrayShort"
            android:background="@drawable/corner_btn_gray"
            android:maxWidth="@dimen/two_btn_single_max_with"
            android:minWidth="@dimen/two_btn_single_min_with"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="@string/cancel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvContent"
            android:layout_marginTop="30dp"
            android:layout_marginStart="20dp"
            android:textColor="@color/color_text_normal"
            app:backgroundShape="RECTANGLE"
            app:cornerRadius="8dp"
            android:textSize="16sp"
            app:strokeWidth="1.5dp"/>

        <com.au.module_android.text.CustomButton
            android:id="@+id/btnSure"
            style="@style/IotButtonPrimaryShort"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvContent"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:layout_marginEnd="20dp"
            android:maxWidth="@dimen/two_btn_single_max_with"
            android:minWidth="@dimen/two_btn_single_min_with"
            android:paddingStart="@dimen/two_btn_single_padding"
            android:paddingEnd="@dimen/two_btn_single_padding"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            app:backgroundShape="RECTANGLE"
            tools:text="delete"
            app:cornerRadius="8dp"/>

        <android.widget.Space
            android:id="@+id/bottomSpace"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSure"
            android:layout_width="1dp"
            android:layout_height="20dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
