<?xml version="1.0" encoding="utf-8"?>
<!-- 长&主题色的背景 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false"
        android:drawable="@drawable/dark_corner_btn_primary_long_disabled">
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/color_text_normal_dark_press"/>
            <corners android:radius="@dimen/two_btn_corner_size"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/color_text_normal_dark"/>
            <corners android:radius="@dimen/two_btn_corner_size"/>
        </shape>
    </item>
</selector>