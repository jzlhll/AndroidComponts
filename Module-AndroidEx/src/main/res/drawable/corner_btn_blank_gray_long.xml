<?xml version="1.0" encoding="utf-8"?>
<!-- 中空有灰色边框的背景 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="@dimen/single_btn_corner_size"/>
            <solid android:color="@color/color_gray_light"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_999999"/>
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="@dimen/single_btn_corner_size"/>
            <stroke
                android:width="1dp"
                android:color="@color/color_999999"/>
        </shape>
    </item>
</selector>