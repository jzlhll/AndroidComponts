<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent">

    <include
        android:id="@+id/toolBar"
        layout="@layout/fake_tool_bar"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_height="48dp" />

    <LinearLayout
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="horizontal"
        android:id="@+id/toolBarRight"
        android:layout_width="wrap_content"
        android:gravity="center"
        android:layout_height="48dp">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/addMenuBtn"
            android:padding="8dp"
            android:scaleType="fitXY"
            android:src="@drawable/ic_add"
            android:layout_width="48dp"
            android:layout_height="48dp"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/removeMenuBtn"
            android:padding="8dp"
            android:scaleType="fitXY"
            android:src="@drawable/ic_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"/>
    </LinearLayout>

    <com.au.module_android.widget.CustomFontText
        android:paddingHorizontal="@dimen/light_ui_padding_edge"
        app:layout_constraintTop_toBottomOf="@id/toolBar"
        android:id="@+id/title"
        android:layout_marginTop="12dp"
        style="@style/StyleTitleBText"
        android:text="自动点击-所有录制方案"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.recyclerview.widget.RecyclerView
        android:paddingHorizontal="@dimen/light_ui_padding_edge"
        android:layout_marginTop="8dp"
        android:id="@+id/rcv"
        app:layout_constraintTop_toBottomOf="@id/title"
        android:layout_width="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="12dp"
        android:layout_height="0dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>