<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#ffffff"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.autooneclick.AutoContinuousClickActivityFragment">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/recordModeHost"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/autoClickHost"
        android:layout_marginTop="16dp"
        android:layout_width="0dp"
        android:layout_marginEnd="12dp"
        android:layout_height="70dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/recordModeBtn"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_width="match_parent"
            android:layout_gravity="center_vertical"
            android:layout_height="50dp"
            android:text="录制方案（todo）"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/autoClickHost"
        app:layout_constraintTop_toTopOf="@id/recordModeHost"
        app:layout_constraintStart_toEndOf="@id/recordModeHost"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"
        android:layout_width="0dp"
        android:layout_height="70dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/autoClickButton"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_width="match_parent"
            android:layout_gravity="center_vertical"
            android:layout_height="50dp"
            android:text="自动点击"/>
    </com.google.android.material.card.MaterialCardView>

    <com.au.module_android.widget.CustomButton
        style="@style/StyleButtonWarn"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/stopAllBtn"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_gravity="center_vertical"
        android:layout_height="50dp"
        android:text="全部停止"/>
</androidx.constraintlayout.widget.ConstraintLayout>