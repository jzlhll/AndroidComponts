<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--想要字体有粗，请命名为XXXBTextXXX。或者额外设置textStyle=bold
        如果想要中粗，则必须命名为XXXMTextXXX 或者额外设置fontMode=mid StyleFontUtil中有改。-->

    <!-- 大标题的样式。字体大小不做限定；自行设置；主要约束了行间距和颜色。 -->
    <style name="StyleTitleBTextDark">
        <item name="android:textColor">@color/color_text_normal_dark</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="StyleFontSecondTitleTextDark">
        <item name="android:textColor">#777777</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:textSize">20sp</item>
        <item name="fontMode">mid</item>
    </style>

    <style name="StyleFontTitleDescTextDark">
        <item name="android:textColor">#6D6D73</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- 一般的字体 -->
    <style name="StyleFontTextDark">
        <item name="android:textColor">@color/color_text_normal_dark</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="StyleFontMenuTextDark">
        <item name="android:textColor">@color/color_text_normal_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="fontMode">mid</item>
    </style>

    <style name="StyleFontSecondaryTextDark">
        <item name="android:textColor">@color/color_text_secondary_dark</item>
        <item name="android:lineSpacingMultiplier">1.05</item>
    </style>

    <!--显示成为中粗-->
    <style name="StyleFontMTextDark" parent="StyleFontTextDark"/>

    <!--显示成为粗-->
    <style name="StyleFontBTextDark" parent="StyleFontTextDark"/>

    <!-- minText 15sp 和 smallText 12sp默认灰色 -->
    <style name="StyleMinTextDark">
        <item name="android:lineSpacingMultiplier">1.05</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#999999</item>
    </style>

    <style name="StyleSmallTextDark">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#999999</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <!-- 假装为输入框的Text样式 -->
    <style name="StyleFakeEditTextDark" parent="StyleFontTextDark">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">#111111</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
