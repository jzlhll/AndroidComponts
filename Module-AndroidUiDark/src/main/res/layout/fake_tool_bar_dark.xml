<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:paddingStart="12dp"
    android:paddingEnd="@dimen/ui_padding_edge"
    xmlns:tools="http://schemas.android.com/tools"
    tools:background="@color/color1f1f1f"
    android:layout_height="48dp">

    <com.au.module_android.widget.CustomFontText
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/title"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="56dp"
        style="@style/StyleFontBTextDark"
        android:textSize="18sp"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Long long long long long long Title"
        android:layout_height="match_parent"/>

    <androidx.appcompat.widget.AppCompatImageView
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/back"
        android:src="@drawable/icon_back_dark"
        android:padding="6dp"
        android:layout_width="48dp"
        android:layout_height="match_parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>